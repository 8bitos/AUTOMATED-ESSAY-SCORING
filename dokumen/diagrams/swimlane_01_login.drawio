        </mxCell>
        
        <mxCell id="enter-cred" value="Enter Email &amp;&#10;Password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="user-swim">
          <mxGeometry x="90" y="210" width="140" height="50" as="geometry"/>
        </mxCell>
        
        <mxCell id="submit" value="Submit Login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f3ff;strokeColor=#000000;" vertex="1" parent="user-swim">
          <mxGeometry x="90" y="320" width="140" height="50" as="geometry"/>
        </mxCell>
        
        <mxCell id="wait-resp" value="Wait for Response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9cc;strokeColor=#000000;" vertex="1" parent="user-swim">
          <mxGeometry x="90" y="450" width="140" height="50" as="geometry"/>
        </mxCell>
        
